{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Java/JSONFold demo - default",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": "--demo --verbose"
        },
        {
            "type": "java",
            "name": "Java JSONFold demo - max",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": "--demo --compact=max --verbose"
        },

        {
            "type": "java",
            "name": "Java JSONFold demo - off",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": "--demo --compact=off --verbose"
        },
                {
            "type": "java",
            "name": "Java benchmark",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Benchmark",
            "projectName": "jsonfold-cli",
            "args": ""
        },
        {
            "name": "benchmark",
            "type": "debugpy",
            "request": "launch",
            "program": "python/benchmark.py",
            "args": []
        },
        {
            "name": "benchmark --dump",
            "type": "debugpy",
            "request": "launch",
            "program": "python/benchmark.py",
            "args": [
                "--dump"
            ]
        },
        {
            "name": "Python Debugger: Unit Test",
            "type": "debugpy",
            "request": "launch",
            "program": "python/jsonfold.py",
            "args": [
                "--input=tests/unit/050.json",
                "--fold-nesting=0",
                "--width=80"
            ]
        },
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        }
    ]
}
