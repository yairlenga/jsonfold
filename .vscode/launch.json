{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Java/JSONFold demo - default",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-jackson",
            "args": "--demo --verbose"
        },
        {
            "type": "java",
            "name": "Java JSONFold demo - max",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-jackson",
            "args": "--demo --compact=max --verbose"
        },

                {
            "type": "java",
            "name": "Java JSONFold demo - off",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-jackson",
            "args": "--demo --compact=off --verbose"
        },
        {
            "name": "benchmark",
            "type": "debugpy",
            "request": "launch",
            "program": "python/benchmark.py",
            "args": []
        },
        {
            "name": "benchmark dump.done",
            "type": "debugpy",
            "request": "launch",
            "program": "python/benchmark.py",
            "args": [
                "jsonfold.dump.none"
            ]
        },
        {
            "name": "Python Debugger: unit/010",
            "type": "debugpy",
            "request": "launch",
            "program": "python/jsonfold.py",
            "args": [
                "--input=tests/unit/010.gold",
                "--compact=pack"
            ]
        },
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        }
    ]
}
