{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Program",
            "program": "${workspaceFolder}/javascript/cli.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node",
            "args": [ "--input=javascript/small.json"]
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-jsonfold",
            "cwd": "${workspaceFolder}/perl",
            "program": "${workspaceFolder}/perl/lib/JSON/JSONFold.pm",
            "stopOnEntry": false,
            "args": [ "--verbose", "--demo", "--compact=off", "--width=10" ]
        },

        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-CLI",
            "cwd": "${workspaceFolder}/perl",
            "program": "${workspaceFolder}/perl/script/jsonfold.pl",
            "stopOnEntry": true,
            "args": [ "--verbose", "--demo", "--compact=high" ]
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-Benchmark",
            "cwd": "${workspaceFolder}/perl",
            "program": "${workspaceFolder}/perl/script/benchmark.pl",
            "stopOnEntry": true,
            "args": [  ]
        },
        {
            "type": "java",
            "name": "Java - Jackson demo",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": "--demo --verbose"
        },

        {
            "type": "java",
            "name": "Java - Jackson Unit",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": [ "--input=tests/future/110.json", "--compact=grid", "--width=120", "--indent=2"]
        },
        {
            "type": "java",
            "name": "Java GSON",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.GsonMain",
            "projectName": "jsonfold-gson",
            "args": [ "--demo", "--verbose", "--sort-keys" ]
        },
                {
            "type": "java",
            "name": "Java benchmark",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Benchmark",
            "projectName": "jsonfold-cli",
            "args": ""
        },
        {
            "name": "python benchmark",
            "type": "debugpy",
            "request": "launch",
            "program": "python/benchmark.py",
            "args": [ "--show=100"]
        },

        {
            "name": "Python jsonfold ",
            "type": "debugpy",
            "request": "launch",
            "program": "python/jsonfold.py",
            "args": [
                "-v", "--input=python/sample.json", "--compact=grid"
            ]
        },
        {
            "name": "Python jsonfold CLI",
            "type": "debugpy",
            "request": "launch",
            "program": "python/jsonfold_cli.py",
            "args": [
                "--input=geo.json", "-v", "--join-nesting=1"
            ]
        },
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        }
    ]
}
