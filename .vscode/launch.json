{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-Debug",
            "cwd": "${workspaceFolder}/perl",
            "program": "${workspaceFolder}/perl/script/jsonfold.pl",
            "stopOnEntry": true,
            "args": [ "--input=../tests/unit/028.json", "--compact=high" ]
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-Benchmark",
            "cwd": "${workspaceFolder}/perl",
            "program": "${workspaceFolder}/perl/script/benchmark.pl",
            "stopOnEntry": true,
            "args": [  ]
        },
        {
            "type": "java",
            "name": "Java/JSONFold demo - default",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": "--demo --verbose"
        },
        {
            "type": "java",
            "name": "Java JSONFold demo - max",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": "--demo --compact=max --verbose"
        },

        {
            "type": "java",
            "name": "Java JSONFold demo - off",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": "--demo --compact=off --verbose"
        },
                {
            "type": "java",
            "name": "Java benchmark",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Benchmark",
            "projectName": "jsonfold-cli",
            "args": ""
        },
        {
            "name": "python benchmark",
            "type": "debugpy",
            "request": "launch",
            "program": "python/benchmark.py",
            "args": [ "--show=100"]
        },
        {
            "name": "benchmark --dump",
            "type": "debugpy",
            "request": "launch",
            "program": "python/benchmark.py",
            "args": [
                "--dump"
            ]
        },
        {
            "name": "Python Debugger: Unit Test",
            "type": "debugpy",
            "request": "launch",
            "program": "python/jsonfold_cli.py",
            "args": [
                "--input=tests/new/053.json", "--compact=pack", "-v", "--pack-nesting=0"
            ]
        },
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        }
    ]
}
