{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C CLI",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/c/jsonfold.exe",
            "args": [ "--verbose", "--input=tests/unit/028.json", "--compact=high" ],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "JavaScript CLI",
            "program": "${workspaceFolder}/javascript/cli.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node",
            "args": [ "--input=tests/misc/webdemo.json", "--width=100", "-v"]
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl jsonfold",
            "cwd": "${workspaceFolder}/perl",
            "program": "${workspaceFolder}/perl/lib/JSON/JSONFold.pm",
            "stopOnEntry": false,
            "args": [ "--verbose", "--demo", "--compact=off", "--width=10" ]
        },

        {
            "type": "perl",
            "request": "launch",
            "name": "Perl CLI",
            "cwd": "${workspaceFolder}/perl",
            "program": "${workspaceFolder}/perl/script/jsonfold.pl",
            "stopOnEntry": true,
            "args": [ "--verbose", "--demo", "--compact=high" ]
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl Benchmark",
            "cwd": "${workspaceFolder}/perl",
            "program": "${workspaceFolder}/perl/script/benchmark.pl",
            "stopOnEntry": true,
            "args": [  ]
        },
        {
            "type": "java",
            "name": "Java - Jackson demo",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": "--demo --verbose"
        },

        {
            "type": "java",
            "name": "Java - Jackson Unit",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Main",
            "projectName": "jsonfold-cli",
            "args": [ "--input=tests/unit/024.json", "--compact=max", "--width=80"]
        },
        {
            "type": "java",
            "name": "Java GSON",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.GsonMain",
            "projectName": "jsonfold-gson",
            "args": [ "--demo", "--verbose", "--sort-keys" ]
        },
                {
            "type": "java",
            "name": "Java benchmark",
            "request": "launch",
            "mainClass": "dev.jsonfold.format.Benchmark",
            "projectName": "jsonfold-cli",
            "args": ""
        },
        {
            "name": "Python Benchmark",
            "type": "debugpy",
            "request": "launch",
            "program": "python/benchmark.py",
            "args": [ "--show=100"]
        },

        {
            "name": "Python CLI",
            "type": "debugpy",
            "request": "launch",
            "program": "python/cli.py",
            "args": [
                "-v", "--input=tests/unit/023.json", "--width=30", "--compact=join"
            ]
        },
        {
            "name": "Python Unit Test",
            "type": "debugpy",
            "request": "launch",
            "program": "python/cli.py",
            "args": [
                "--input=tests/future/109.json", "-v", "--compact=max", "--join-obj-items=5"
            ]
        },
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        }
    ]
}
