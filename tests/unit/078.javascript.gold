{
  "meta": {
    "test": "negative decimal numbers", "version": 1
  },
  "target": {
    "changes": [
      -1, -2.5, 3.14, -7, 1000
    ]
  },
  "positive_sibling": {
    "totals": [
      10, 20, 30, 40
    ]
  },
  "negative_sibling": {
    "measurements": [
      -123456789.12345, -987654321.98765, 1.2345e-7
    ]
  }
}
